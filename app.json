{
  "expo": {
    "name": "Giftyy",
    "slug": "giftyy",
    "version": "1.0.0",
    "description": "Because every gift deserves a story",
    "orientation": "portrait",
    "icon": "./assets/images/giftyy.png",
    "scheme": "giftyy",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#f75507",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:giftyy.store"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to record a short video message for the gift.",
        "NSMicrophoneUsageDescription": "This app uses the microphone while recording your video message.",
        "NSPhotoLibraryUsageDescription": "This app uses your photo library to allow you to upload memories for your gifts.",
        "NSContactsUsageDescription": "Giftyy uses your contacts to help you find friends and send them gifts.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.giftyy.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/giftyy-adaptive-icon.png",
        "backgroundImage": "./assets/images/giftyy.png",
        "monochromeImage": "./assets/images/giftyy-adaptive-icon.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 25,
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "READ_CONTACTS"
      ],
      "package": "com.giftyy.app",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.giftyy.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "giftyy.store",
              "pathPrefix": "/gift"
            },
            {
              "scheme": "https",
              "host": "giftyy.store",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/giftyy.png"
    },
    "plugins": [
      "./plugins/withGradle8.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/giftyy.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-vision-camera",
      "expo-video",
      "expo-audio",
      "expo-camera",
      "expo-contacts",
      "expo-notifications",
      "expo-image-picker",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "enableGooglePay": true
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "notes": {
        "associatedDomains": "The apple-app-site-association file must exist at https://giftyy.store/.well-known/apple-app-site-association"
      },
      "eas": {
        "projectId": "67ba6b4a-d0c0-4d22-89f3-8a2d2fc09a36"
      }
    },
    "owner": "rtarbaris-organization"
  }
}
